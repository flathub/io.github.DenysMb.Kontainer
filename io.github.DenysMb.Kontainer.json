{
    "app-id": "io.github.DenysMb.Kontainer",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.9",
    "sdk": "org.kde.Sdk",
    "command": "kontainer",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--talk-name=org.freedesktop.Flatpak",
        "--filesystem=~/.local/share/applications:ro",
        "--filesystem=~/.local/share/icons/distrobox:ro"
    ],
    "modules": [
        {
            "name": "kontainer",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DCMAKE_BUILD_TYPE=Release"
            ],
            "builddir": true,
            "sources": [
                {
                    "type": "git",
                    "url": "https://invent.kde.org/denysmb/Kontainer.git",
                    "tag": "1.4.0",
                    "commit": "31e12aa5bfa88f5cdb0b09f5cdfd077d75b3da66"
                }
            ]
        }
    ]
}
